:root {
    --bg-card: #1e293b;
    --bg-hover: #334155;
    --line: rgba(148, 163, 184, 0.15);
    --line-strong: rgba(148, 163, 184, 0.25);
    --ink: #f1f5f9;
    --muted: #94a3b8;
    --accent: #3b82f6;
    --accent-light: #60a5fa;
    --accent-dark: #1e40af;
    --accent-soft: rgba(59, 130, 246, 0.1);
    --success: #10b981;
    --warning: #f59e0b;
    --shadow: 0 20px 25px rgba(0, 0, 0, 0.3);
    --shadow-soft: 0 4px 12px rgba(0, 0, 0, 0.15);
}

* {
    box-sizing: border-box;
}

html,
body {
    height: 100%;
}

body {
    margin: 0;
    background: linear-gradient(135deg, var(--bg) 0%, var(--bg-soft) 100%);
    color: var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    font-size: 14px;
    line-height: 1.5;
}

