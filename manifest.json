{
  "manifest_version": 3,
  "name": "Nerd Tab",
  "version": "1.0.0",
  "description": "A premium study-focused productivity dashboard. Replace your new tab with a complete academic control center.",
  "permissions": ["storage", "alarms"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["newtab.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Nerd Tab"
  }
}
