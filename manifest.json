{
  "manifest_version": 3,
  "name": "Nerd Tab",
  "version": "1.0.0",
  "description": "A premium study-focused productivity dashboard. Replace your new tab with a complete academic control center.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/data.json",
        "styles.css",
        "app.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Nerd Tab"
  }
}